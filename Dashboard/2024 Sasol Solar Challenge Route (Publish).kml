</SimpleField>
		<SimpleField type="string" name="Status"><displayName>&lt;b&gt;Status&lt;/b&gt;</displayName>
</SimpleField>
		<SimpleField type="string" name="Start_Date"><displayName>&lt;b&gt;Start Date&lt;/b&gt;</displayName>
</SimpleField>
