  <tr><td><b>Time</b></td><td>$[MovementReport/Time]</td></tr>
  <tr><td><b>Lat</b></td><td>$[MovementReport/Lat]</td></tr>
  <tr><td><b>Long</b></td><td>$[MovementReport/Long]</td></tr>
  <tr><td><b>Speed Limit</b></td><td>$[MovementReport/Speed_Limit]</td></tr>
</table>]]></text>
		</BalloonStyle>
	</Style>
